{
  "sourceLanguage": "en",
  "strings": {
    "navigator.settings.camera.unavailable": {
      "comment": "Placeholder shown in Navigator settings when shared camera controls are unavailable in the current environment.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Camera controls are unavailable in this environment."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この環境ではカメラ設定を利用できません。"
          }
        }
      }
    },
    "navigator.settings.section.camera": {
      "comment": "Title for the camera section in Navigator settings.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Camera"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "カメラ"
          }
        }
      }
    },
    "navigator.camera.statusItem.lastError.format": {
      "comment": "Tooltip line in the camera status item describing the most recent error when no newer diagnostic event is available.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Last error: %@"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最後のエラー: %@"
          }
        }
      }
    },
    "navigator.camera.statusItem.browserTransport.format": {
      "comment": "Tooltip line in the camera status item summarizing tracked browser transport tabs, managed track count, and browser-process fallback usage for Navigator Camera.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Browser transport: tabs %d • Tracks: %d • Fallback: %d"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ブラウザ転送: タブ %d • トラック %d • フォールバック %d"
          }
        }
      }
    },
    "navigator.camera.statusItem.latestEvent.format": {
      "comment": "Tooltip line in the camera status item describing the latest camera routing or processing event.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Latest event: %@"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最新イベント: %@"
          }
        }
      }
    },
    "navigator.camera.statusItem.pipeline.format": {
      "comment": "Tooltip line in the camera status item describing the currently active managed camera pipeline implementation, warmup profile, and filter count.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pipeline: %@ • %@ • %d filters"
